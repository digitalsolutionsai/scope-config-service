# This file contains environment variables for the application.
# Copy this file to .env and replace the values with your own.

# -- Database --
# If DATABASE_URL is set, PostgreSQL is used.
# If DATABASE_URL is NOT set, SQLite is used as the default (no external DB required).
#
# For PostgreSQL:
#   DATABASE_URL=postgresql://user:password@postgres:5555/config_db?sslmode=disable
#
# For SQLite (default when DATABASE_URL is not set):
#   SQLITE_DB_PATH=/app/data/config.db   (default: data/config.db)

# -- PostgreSQL --
# These variables are used by the compose.postgres.yml file to configure PostgreSQL.
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=config_db
POSTGRESQL_FORWARD_PORT=5555

# -- pgAdmin --
# These variables are used by the compose.postgres.yml file to configure pgAdmin.
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin
PGADMIN_FORWARD_PORT=8888

# -- Config Service --
# This variable is used by the compose.yml file to configure the config-service.
# It should use the variables defined above to connect to the PostgreSQL container.
# Comment out or remove DATABASE_URL to use SQLite instead.
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5555/${POSTGRES_DB}?sslmode=disable

# -- Server Ports --
# The config service now runs both gRPC and HTTP in the same container
# GRPC_PORT=50051
# HTTP_PORT=8080

# -- Authentication --
# Authentication is handled at the API Gateway level (e.g., Spring Gateway).
# This service exposes public APIs and relies on the gateway for auth/authz.
